{
  "name": "tella-cli",
  "version": "0.1.0",
  "description": "CLI for the Tella video API - videos, sources, clips, playlists, webhooks. Made with api2cli.dev.",
  "type": "module",
  "bin": {
    "tella-cli": "./dist/tella-cli.js"
  },
  "files": [
    "dist/tella-cli.js",
    "README.md"
  ],
  "keywords": [
    "tella",
    "cli",
    "video",
    "transcript",
    "screen-recording",
    "api2cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Melvynx/tella-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Melvynx/tella-cli/issues"
  },
  "homepage": "https://github.com/Melvynx/tella-cli#readme",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/tella-cli.js --target bun",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
